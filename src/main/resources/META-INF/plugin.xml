<idea-plugin>
    <id>com.github.guillaume.taffin.matlab-intellij</id>
    <name>Matlab</name>
    <vendor email="guillaume.taffinjob@gmail.com" url="https://github.com/GuillaumeTaffin/matlab-intellij">Guillaume Taffin</vendor>

    <description><![CDATA[
    Full Matlab language support for Jetbrains IDEs.
    ]]></description>

    <!-- please see https://plugins.jetbrains.com/docs/intellij/plugin-compatibility.html
         on how to target different products -->
    <depends>com.intellij.modules.platform</depends>

    <extensions defaultExtensionNs="com.intellij">
        <fileType name="Matlab File"
                  implementationClass="com.github.gt.matlab.language.MatlabFileType"
                  fieldName="INSTANCE"
                  language="Matlab"
                  extensions="m"/>
    </extensions>

    <actions>
        <!-- Add your actions here -->
    </actions>
</idea-plugin>